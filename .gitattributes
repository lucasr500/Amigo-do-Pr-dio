# Normaliza fim de linha: o repositório guarda LF e faz checkout em LF, mesmo no Windows.
# Blinda a lane contra a conversão CRLF do OneDrive (que gerava churn e risco de truncamento).
* text=auto eol=lf

# SQL sempre LF (migrations aplicadas por supabase db reset).
*.sql text eol=lf

# Binários: nunca normalizar.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.webp binary
*.woff binary
*.woff2 binary
